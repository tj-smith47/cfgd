# Ignore everything
**

# Allow project structure
!*/
!.gitignore
!.gitattributes
!.dockerignore
!.editorconfig
!.github/
!.github/**

# Rust source
!Cargo.toml
!Cargo.lock
!crates/
!crates/**

# Config and schemas
!schemas/
!schemas/**
!examples/
!examples/**

# Docker and deployment
!Dockerfile*
!chart/
!chart/**
!manifests/
!manifests/**

# Crossplane function
!function-cfgd/
!function-cfgd/**

# Ecosystem integration
!policies/
!policies/**
!ecosystem/
!ecosystem/**

# CI, tasks, and release config
!.anodizer.yaml
!.anodizer/
!.anodizer/**
!cfgd.spec
!cliff.toml
/dist/
# Determinism-harness scratch (anodizer `check determinism`): hermetic build
# worktrees plus their cargo cache. Multi-GB, regenerated each run, never tracked.
# The allowlist's `!*/` re-includes every directory, so without an explicit
# re-ignore these surface as untracked and a `git add -A` would stage them.
/.det-tmp/
/.det-worktrees/
!scripts/
!scripts/**
!Taskfile.yml

# Native OS packaging consumed by the nfpm release stage: the systemd unit,
# maintainer scripts (post/pre install/remove), and the default
# /etc/cfgd/config.yaml conffile. Must be tracked or a CI checkout builds
# deb/rpm/apk without the daemon service wiring.
!packaging/
!packaging/**

# Claude project config — only files load-bearing for CI / hooks / planning are tracked.
# Everything else under .claude/ stays on disk but is intentionally local-only.
!.claude/
!.claude/hooks/
!.claude/hooks/post-edit-rs.sh
!.claude/hooks/validate-commands.sh
!.claude/scripts/
!.claude/scripts/audit.sh
!.claude/scripts/audit-tests/
!.claude/scripts/audit-tests/**
!.claude/scripts/publish-coverage.sh
!.claude/scripts/coverage-percent.sh
!.claude/rules/
!.claude/rules/**
.claude/rules/user-layer-notes.md
!.claude/plans/
!.claude/plans/upstream-kubernetes.md

# Tests
!tests/
!tests/**

# Docs
!docs/
!docs/**
!/README.md
!/CHANGELOG.md
!/CONTRIBUTING.md
!/CODE_OF_CONDUCT.md
!/SECURITY.md
!/LICENSE
!/LICENSE-MIT
!/LICENSE-APACHE

# Re-ignore build artifacts inside allowed dirs
target/
**/*.rs.bk

# Re-ignore OS/IDE junk inside allowed dirs
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/

# Re-ignore env files inside allowed dirs
.env
.env.*
function-cfgd/function-cfgd
CLAUDE.local.md
.claude/local/
.claude/scratch/
.claude/audits/
.claude/worktrees/
