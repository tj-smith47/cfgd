# Ignore everything
**

# Allow project structure
!*/
!.gitignore
!.dockerignore
!.editorconfig
!.github/
!.github/**

# Rust source
!Cargo.toml
!Cargo.lock
!crates/
!crates/**

# Config and schemas
!schemas/
!schemas/**
!examples/
!examples/**

# Docker and deployment
!Dockerfile*
!chart/
!chart/**
!manifests/
!manifests/**

# Crossplane function
!function-cfgd/
!function-cfgd/**

# Ecosystem integration
!policies/
!policies/**
!ecosystem/
!ecosystem/**

# CI, tasks, and release config
!.anodize.yaml
!cfgd.spec
!cliff.toml
/dist/
!scripts/
!scripts/**
!Taskfile.yml

# Claude project config (plans, scripts, skills, hooks)
!.claude/
!.claude/*.md
!.claude/scripts/
!.claude/scripts/**
!.claude/skills/
!.claude/skills/**
!.claude/hooks/
!.claude/hooks/**

# Tests
!tests/
!tests/**

# Docs
!docs/
!docs/**
!README.md
!CHANGELOG.md
!CONTRIBUTING.md
!CODE_OF_CONDUCT.md
!SECURITY.md
!LICENSE

# Re-ignore build artifacts inside allowed dirs
target/
**/*.rs.bk

# Re-ignore OS/IDE junk inside allowed dirs
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/

# Re-ignore env files inside allowed dirs
.env
.env.*
function-cfgd/function-cfgd
