          "description": "Update policy for authored skills. Defaults to inheriting `policy`."
        }
      },
      "type": "object"
    },
    "UpdatePolicy": {
      "description": "Update policy governing how cfgd self-update checks behave.\n\n`Auto` applies updates without prompting, `Prompt` asks before applying, `Notify` only reports that an update is available, and `Manual` disables automatic checks entirely (the user runs `cfgd upgrade` themselves).",
      "oneOf": [
        {
          "description": "Apply updates automatically without prompting.",
          "enum": [
            "Auto"
          ],
          "type": "string"
        },
        {
          "description": "Ask before applying an available update.",
          "enum": [
            "Prompt"
          ],
          "type": "string"
        },
        {
          "description": "Report that an update is available, but take no action.",
          "enum": [
            "Notify"
          ],
          "type": "string"
        },
        {
          "description": "Disable automatic update checks; the user upgrades manually.",
          "enum": [
            "Manual"
          ],
          "type": "string"
        }
      ]
    }
  },
