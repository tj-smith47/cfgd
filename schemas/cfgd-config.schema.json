{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://cfgd.io/schemas/cfgd-config.schema.json",
  "title": "cfgd Config",
  "description": "Root configuration file for cfgd (cfgd.yaml)",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "type": "string",
      "description": "API version identifier",
      "examples": ["cfgd.io/v1alpha1"]
    },
    "kind": {
      "type": "string",
      "const": "Config",
      "description": "Document kind, must be 'Config'"
    },
    "metadata": {
      "$ref": "#/$defs/ConfigMetadata"
    },
    "spec": {
      "$ref": "#/$defs/ConfigSpec"
    }
  },
  "$defs": {
    "ConfigMetadata": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of this configuration"
        }
      }
    },
    "ConfigSpec": {
      "type": "object",
      "required": ["profile"],
      "additionalProperties": false,
      "properties": {
        "profile": {
          "type": "string",
          "description": "Name of the active profile to apply"
        },
        "origin": {
          "description": "Git or server origin(s). Can be a single object or an array.",
          "oneOf": [
            { "$ref": "#/$defs/OriginSpec" },
            {
              "type": "array",
              "items": { "$ref": "#/$defs/OriginSpec" }
            }
          ]
        },
        "daemon": {
          "$ref": "#/$defs/DaemonConfig"
        },
        "secrets": {
          "$ref": "#/$defs/SecretsConfig"
        },
        "sources": {
          "type": "array",
          "items": { "$ref": "#/$defs/SourceSpec" },
          "default": [],
          "description": "Multi-source config subscriptions"
        },
        "theme": {
          "$ref": "#/$defs/ThemeConfig"
        },
        "modules": {
          "$ref": "#/$defs/ModulesConfig"
        },
        "fileStrategy": {
          "$ref": "#/$defs/FileStrategy"
        },
        "security": {
          "$ref": "#/$defs/SecurityConfig"
        },
        "aliases": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "default": {},
          "description": "CLI aliases: map of alias name to command string"
        },
        "ai": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "provider": { "type": "string", "default": "claude", "description": "AI provider name" },
            "model": { "type": "string", "default": "claude-sonnet-4-6", "description": "Model identifier" },
            "apiKeyEnv": { "type": "string", "default": "ANTHROPIC_API_KEY", "description": "Environment variable name for the API key" }
          },
          "description": "AI assistant configuration for cfgd generate"
        }
      }
    },
    "SecurityConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allowUnsigned": {
          "type": "boolean",
          "default": false,
          "description": "Allow unsigned source content even when sources require signed commits. Intended for development/testing."
        }
      }
    },
    "ModulesConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "registries": {
          "type": "array",
          "items": { "$ref": "#/$defs/ModuleRegistryEntry" },
          "default": [],
          "description": "Module registries — git repos containing modules"
        },
        "security": {
          "$ref": "#/$defs/ModuleSecurityConfig"
        }
      }
    },
    "ModuleRegistryEntry": {
      "type": "object",
      "required": ["name", "url"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Short name / alias for this registry"
        },
        "url": {
          "type": "string",
          "description": "Git URL of the registry repository"
        }
      }
    },
    "ModuleSecurityConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requireSignatures": {
          "type": "boolean",
          "default": false,
          "description": "Require GPG/SSH signatures on all remote module tags"
        }
      }
    },
    "FileStrategy": {
      "type": "string",
      "enum": ["Symlink", "Copy", "Template", "Hardlink"],
      "default": "Symlink",
      "description": "File deployment strategy"
    },
    "OriginSpec": {
      "type": "object",
      "required": ["type", "url"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["Git", "Server"],
          "description": "Origin type"
        },
        "url": {
          "type": "string",
          "description": "Repository URL or server endpoint"
        },
        "branch": {
          "type": "string",
          "default": "main",
          "description": "Branch to track"
        },
        "auth": {
          "type": "string",
          "description": "Authentication method or credential reference"
        }
      }
    },
    "DaemonConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Whether the daemon is enabled"
        },
        "reconcile": {
          "$ref": "#/$defs/ReconcileConfig"
        },
        "sync": {
          "$ref": "#/$defs/SyncConfig"
        },
        "notify": {
          "$ref": "#/$defs/NotifyConfig"
        }
      }
    },
    "ReconcileConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "interval": {
          "type": "string",
          "default": "5m",
          "description": "How often to reconcile (e.g. '5m', '1h')"
        },
        "onChange": {
          "type": "boolean",
          "default": false,
          "description": "Whether to reconcile immediately on file change"
        },
        "autoApply": {
          "type": "boolean",
          "default": false,
          "description": "Automatically apply reconciled changes without prompting"
        },
        "policy": {
          "$ref": "#/$defs/AutoApplyPolicyConfig"
        },
        "driftPolicy": {
          "type": "string",
          "enum": ["Auto", "NotifyOnly", "Prompt"],
          "default": "NotifyOnly",
          "description": "Policy for daemon drift reconciliation: Auto (apply), NotifyOnly (default), Prompt"
        },
        "patches": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "kind": { "type": "string", "enum": ["Module", "Profile"] },
              "name": { "type": "string" },
              "interval": { "type": "string" },
              "autoApply": { "type": "boolean" },
              "driftPolicy": { "type": "string", "enum": ["Auto", "NotifyOnly", "Prompt"] }
            },
            "required": ["kind"]
          },
          "description": "Per-module or per-profile reconcile overrides"
        }
      }
    },
    "AutoApplyPolicyConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "newRecommended": {
          "$ref": "#/$defs/PolicyAction"
        },
        "newOptional": {
          "$ref": "#/$defs/PolicyAction"
        },
        "lockedConflict": {
          "$ref": "#/$defs/PolicyAction"
        }
      }
    },
    "PolicyAction": {
      "type": "string",
      "enum": ["Notify", "Accept", "Reject", "Ignore"],
      "description": "Action to take for auto-apply policy decisions"
    },
    "SyncConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "autoPush": {
          "type": "boolean",
          "default": false,
          "description": "Automatically push local changes to origin"
        },
        "autoPull": {
          "type": "boolean",
          "default": false,
          "description": "Automatically pull remote changes"
        },
        "interval": {
          "type": "string",
          "default": "1h",
          "description": "Sync interval (e.g. '1h', '30m')"
        }
      }
    },
    "NotifyConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "drift": {
          "type": "boolean",
          "default": false,
          "description": "Send notifications on drift detection"
        },
        "method": {
          "type": "string",
          "enum": ["Desktop", "Stdout", "Webhook"],
          "default": "Desktop",
          "description": "Notification delivery method"
        },
        "webhookUrl": {
          "type": "string",
          "description": "Webhook URL (required when method is 'Webhook')"
        }
      }
    },
    "SecretsConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "backend": {
          "type": "string",
          "default": "sops",
          "description": "Primary secrets backend"
        },
        "sops": {
          "$ref": "#/$defs/SopsConfig"
        },
        "integrations": {
          "type": "array",
          "items": { "$ref": "#/$defs/SecretIntegration" },
          "default": [],
          "description": "External secret provider integrations"
        }
      }
    },
    "SopsConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ageKey": {
          "type": "string",
          "description": "Path to age key file for SOPS decryption"
        }
      }
    },
    "SecretIntegration": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Integration name (e.g. '1password', 'bitwarden', 'lastpass', 'vault')"
        }
      },
      "additionalProperties": true
    },
    "SourceSpec": {
      "type": "object",
      "required": ["name", "origin"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Unique name for this source"
        },
        "origin": {
          "$ref": "#/$defs/OriginSpec"
        },
        "subscription": {
          "$ref": "#/$defs/SubscriptionSpec"
        },
        "sync": {
          "$ref": "#/$defs/SourceSyncSpec"
        }
      }
    },
    "SubscriptionSpec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "profile": {
          "type": "string",
          "description": "Specific profile to subscribe to from this source"
        },
        "priority": {
          "type": "integer",
          "default": 500,
          "minimum": 0,
          "description": "Merge priority (higher = wins conflicts)"
        },
        "acceptRecommended": {
          "type": "boolean",
          "default": false,
          "description": "Automatically accept recommended items from source"
        },
        "optIn": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Optional items to opt into"
        },
        "overrides": {
          "description": "Local overrides for source-provided config"
        },
        "reject": {
          "description": "Items to reject from this source"
        }
      }
    },
    "SourceSyncSpec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "interval": {
          "type": "string",
          "default": "1h",
          "description": "How often to sync from this source"
        },
        "autoApply": {
          "type": "boolean",
          "default": false,
          "description": "Automatically apply changes from this source"
        },
        "pinVersion": {
          "type": "string",
          "description": "Pin to a specific version (git tag/commit)"
        }
      }
    },
    "ThemeConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "default": "default",
          "description": "Theme name"
        },
        "overrides": {
          "$ref": "#/$defs/ThemeOverrides"
        }
      }
    },
    "ThemeOverrides": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "success": { "type": "string", "description": "Color for success messages" },
        "warning": { "type": "string", "description": "Color for warning messages" },
        "error": { "type": "string", "description": "Color for error messages" },
        "info": { "type": "string", "description": "Color for info messages" },
        "muted": { "type": "string", "description": "Color for muted/secondary text" },
        "header": { "type": "string", "description": "Color for headers" },
        "subheader": { "type": "string", "description": "Color for subheaders" },
        "key": { "type": "string", "description": "Color for key labels" },
        "value": { "type": "string", "description": "Color for values" },
        "diffAdd": { "type": "string", "description": "Color for diff additions" },
        "diffRemove": { "type": "string", "description": "Color for diff removals" },
        "diffContext": { "type": "string", "description": "Color for diff context lines" },
        "iconSuccess": { "type": "string", "description": "Icon for success" },
        "iconWarning": { "type": "string", "description": "Icon for warnings" },
        "iconError": { "type": "string", "description": "Icon for errors" },
        "iconInfo": { "type": "string", "description": "Icon for info" },
        "iconPending": { "type": "string", "description": "Icon for pending state" },
        "iconArrow": { "type": "string", "description": "Icon for arrows/pointers" }
      }
    }
  }
}
