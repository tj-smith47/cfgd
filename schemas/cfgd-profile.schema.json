{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://cfgd.io/schemas/cfgd-profile.schema.json",
  "title": "cfgd Profile",
  "description": "Profile document for cfgd (profiles/*.yaml)",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "type": "string",
      "description": "API version identifier",
      "examples": ["cfgd.io/v1alpha1"]
    },
    "kind": {
      "type": "string",
      "const": "Profile",
      "description": "Document kind, must be 'Profile'"
    },
    "metadata": {
      "$ref": "#/$defs/ProfileMetadata"
    },
    "spec": {
      "$ref": "#/$defs/ProfileSpec"
    }
  },
  "$defs": {
    "ProfileMetadata": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of this profile"
        }
      }
    },
    "ProfileSpec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "inherits": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "List of parent profile names to inherit from"
        },
        "modules": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Module names to include in this profile"
        },
        "variables": {
          "type": "object",
          "additionalProperties": true,
          "default": {},
          "description": "Key-value variables available for template interpolation"
        },
        "packages": {
          "$ref": "#/$defs/PackagesSpec"
        },
        "files": {
          "$ref": "#/$defs/FilesSpec"
        },
        "system": {
          "type": "object",
          "additionalProperties": true,
          "default": {},
          "description": "System configuration keyed by configurator domain (e.g. defaults, environment)"
        },
        "secrets": {
          "type": "array",
          "items": { "$ref": "#/$defs/SecretSpec" },
          "default": [],
          "description": "Secrets to decrypt and place on the system"
        },
        "scripts": {
          "$ref": "#/$defs/ScriptSpec"
        }
      }
    },
    "PackagesSpec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "brew": {
          "$ref": "#/$defs/BrewSpec"
        },
        "apt": {
          "$ref": "#/$defs/AptSpec"
        },
        "cargo": {
          "$ref": "#/$defs/CargoSpec"
        },
        "npm": {
          "$ref": "#/$defs/NpmSpec"
        },
        "pipx": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Python packages to install via pipx"
        },
        "dnf": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "DNF/Fedora packages to install"
        },
        "apk": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Alpine APK packages to install"
        },
        "pacman": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Arch Linux pacman packages to install"
        },
        "zypper": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "openSUSE zypper packages to install"
        },
        "yum": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "YUM/RHEL packages to install"
        },
        "pkg": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "FreeBSD pkg packages to install"
        },
        "snap": {
          "$ref": "#/$defs/SnapSpec"
        },
        "flatpak": {
          "$ref": "#/$defs/FlatpakSpec"
        },
        "nix": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Nix packages to install"
        },
        "go": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Go packages to install via go install"
        },
        "custom": {
          "type": "array",
          "items": { "$ref": "#/$defs/CustomManagerSpec" },
          "default": [],
          "description": "Custom package manager definitions"
        }
      }
    },
    "BrewSpec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "file": {
          "type": "string",
          "description": "Path to a Brewfile for batch installation"
        },
        "taps": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Homebrew taps to add"
        },
        "formulae": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Homebrew formulae to install"
        },
        "casks": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Homebrew casks to install"
        }
      }
    },
    "AptSpec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "file": {
          "type": "string",
          "description": "Path to a file listing APT packages (one per line)"
        },
        "packages": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "APT packages desired on the system"
        }
      }
    },
    "CargoSpec": {
      "description": "Cargo packages. Can be a list of package names or an object with file/packages keys.",
      "oneOf": [
        {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of cargo packages to install"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "file": {
              "type": "string",
              "description": "Path to a file listing cargo packages"
            },
            "packages": {
              "type": "array",
              "items": { "type": "string" },
              "default": [],
              "description": "Cargo packages to install globally"
            }
          }
        }
      ]
    },
    "NpmSpec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "file": {
          "type": "string",
          "description": "Path to a file listing npm packages"
        },
        "global": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "NPM packages to install globally"
        }
      }
    },
    "SnapSpec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "packages": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Snap packages to install (strict confinement)"
        },
        "classic": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Snap packages to install with classic confinement"
        }
      }
    },
    "FlatpakSpec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "packages": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Flatpak application IDs to install"
        },
        "remote": {
          "type": "string",
          "description": "Flatpak remote name (defaults to flathub)"
        }
      }
    },
    "CustomManagerSpec": {
      "type": "object",
      "required": ["name", "check", "list-installed", "install", "uninstall"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Name identifier for this custom package manager"
        },
        "check": {
          "type": "string",
          "description": "Command to check if the package manager is available"
        },
        "list-installed": {
          "type": "string",
          "description": "Command to list installed packages"
        },
        "install": {
          "type": "string",
          "description": "Command template to install a package"
        },
        "uninstall": {
          "type": "string",
          "description": "Command template to uninstall a package"
        },
        "update": {
          "type": "string",
          "description": "Command template to update a package"
        },
        "packages": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Packages to manage with this custom manager"
        }
      }
    },
    "FilesSpec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "managed": {
          "type": "array",
          "items": { "$ref": "#/$defs/ManagedFileSpec" },
          "default": [],
          "description": "Files to manage (copy/template from source to target)"
        },
        "permissions": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "default": {},
          "description": "File permission overrides (path -> mode, e.g. '0600')"
        }
      }
    },
    "ManagedFileSpec": {
      "type": "object",
      "required": ["source", "target"],
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "description": "Source file path relative to the config repo"
        },
        "target": {
          "type": "string",
          "description": "Absolute target path on the system"
        },
        "strategy": {
          "type": "string",
          "enum": ["symlink", "copy", "template", "hardlink"],
          "description": "Per-file deployment strategy override"
        },
        "private": {
          "type": "boolean",
          "default": false,
          "description": "When true, the source file is local-only: auto-added to .gitignore, silently skipped on machines where it doesn't exist"
        }
      }
    },
    "SecretSpec": {
      "type": "object",
      "required": ["source", "target"],
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "description": "Encrypted source file path"
        },
        "target": {
          "type": "string",
          "description": "Target path for decrypted secret"
        },
        "template": {
          "type": "string",
          "description": "Template to render with secret values"
        },
        "backend": {
          "type": "string",
          "description": "Override the default secrets backend for this secret"
        }
      }
    },
    "ScriptSpec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pre-reconcile": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Scripts to run before reconciliation"
        },
        "post-reconcile": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Scripts to run after reconciliation"
        }
      }
    }
  }
}
