        "pacman": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "pipx": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "pkg": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "scoop": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "snap": {
          "anyOf": [
            {
              "$ref": "#/definitions/SnapSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
