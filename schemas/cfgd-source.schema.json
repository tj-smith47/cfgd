    "ConfigSourceSpec": {
      "additionalProperties": false,
      "properties": {
        "policy": {
          "allOf": [
            {
              "$ref": "#/definitions/ConfigSourcePolicy"
            }
          ],
          "default": {
            "constraints": {
              "allowSystemChanges": false,
              "allowedTargetPaths": [],
              "noScripts": true,
              "noSecretsRead": true,
              "requireSignedCommits": false
            },
            "locked": {
              "aliases": [],
              "env": [],
              "files": [],
              "modules": [],
              "packages": null,
              "profiles": [],
              "secrets": [],
              "system": {}
