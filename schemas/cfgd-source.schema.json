        "dnf": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "flatpak": {
          "anyOf": [
            {
              "$ref": "#/definitions/FlatpakSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "go": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "nix": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "npm": {
          "anyOf": [
            {
              "$ref": "#/definitions/NpmSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null
