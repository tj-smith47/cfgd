    "ConfigSourceProfileEntry": {
      "additionalProperties": false,
      "description": "Detailed profile entry in a ConfigSource manifest. When present, provides richer info than the flat `profiles` list.",
      "properties": {
        "description": {
          "default": null,
          "type": [
            "string",
            "null"
