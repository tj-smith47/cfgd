{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://cfgd.io/schemas/cfgd-source.schema.json",
  "title": "cfgd ConfigSource",
  "description": "ConfigSource manifest published by teams for multi-source config management (cfgd-source.yaml)",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "type": "string",
      "description": "API version identifier",
      "examples": ["cfgd.io/v1alpha1"]
    },
    "kind": {
      "type": "string",
      "const": "ConfigSource",
      "description": "Document kind, must be 'ConfigSource'"
    },
    "metadata": {
      "$ref": "#/$defs/ConfigSourceMetadata"
    },
    "spec": {
      "$ref": "#/$defs/ConfigSourceSpec"
    }
  },
  "$defs": {
    "ConfigSourceMetadata": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of this config source"
        },
        "version": {
          "type": "string",
          "description": "Semantic version of this source manifest"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description"
        }
      }
    },
    "ConfigSourceSpec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provides": {
          "$ref": "#/$defs/ConfigSourceProvides"
        },
        "policy": {
          "$ref": "#/$defs/ConfigSourcePolicy"
        }
      }
    },
    "ConfigSourceProvides": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "profiles": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Profile names provided by this source"
        },
        "profile-details": {
          "type": "array",
          "items": { "$ref": "#/$defs/ConfigSourceProfileEntry" },
          "default": [],
          "description": "Detailed profile entries with descriptions and metadata"
        },
        "platform-profiles": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "default": {},
          "description": "Map of platform identifier to default profile name for that platform"
        },
        "modules": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Module names provided by this source"
        }
      }
    },
    "ConfigSourceProfileEntry": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Profile name"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of the profile"
        },
        "path": {
          "type": "string",
          "description": "Path to the profile file within the source"
        },
        "inherits": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Profiles this profile inherits from"
        }
      }
    },
    "ConfigSourcePolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required": {
          "$ref": "#/$defs/PolicyItems",
          "description": "Items that subscribers must accept"
        },
        "recommended": {
          "$ref": "#/$defs/PolicyItems",
          "description": "Items accepted when accept-recommended is true"
        },
        "optional": {
          "$ref": "#/$defs/PolicyItems",
          "description": "Items available via explicit opt-in"
        },
        "locked": {
          "$ref": "#/$defs/PolicyItems",
          "description": "Items that cannot be overridden by subscribers"
        },
        "constraints": {
          "$ref": "#/$defs/SourceConstraints"
        }
      }
    },
    "PolicyItems": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "packages": {
          "$ref": "#/$defs/PackagesSpec"
        },
        "files": {
          "type": "array",
          "items": { "$ref": "#/$defs/ManagedFileSpec" },
          "default": [],
          "description": "Files provided at this policy level"
        },
        "variables": {
          "type": "object",
          "additionalProperties": true,
          "default": {},
          "description": "Variables provided at this policy level"
        },
        "system": {
          "type": "object",
          "additionalProperties": true,
          "default": {},
          "description": "System config provided at this policy level"
        },
        "profiles": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Sub-profiles included at this policy level"
        },
        "modules": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Modules included at this policy level"
        }
      }
    },
    "SourceConstraints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "no-scripts": {
          "type": "boolean",
          "default": true,
          "description": "Prevent this source from running scripts"
        },
        "no-secrets-read": {
          "type": "boolean",
          "default": true,
          "description": "Prevent this source from reading secrets"
        },
        "allowed-target-paths": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Glob patterns for allowed file target paths"
        },
        "allow-system-changes": {
          "type": "boolean",
          "default": false,
          "description": "Whether this source can make system-level changes"
        },
        "require-signed-commits": {
          "type": "boolean",
          "default": false,
          "description": "Require that the HEAD commit in this source's git repo has a valid GPG or SSH signature"
        }
      }
    },
    "PackagesSpec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "brew": {
          "$ref": "#/$defs/BrewSpec"
        },
        "apt": {
          "$ref": "#/$defs/AptSpec"
        },
        "cargo": {
          "$ref": "#/$defs/CargoSpec"
        },
        "npm": {
          "$ref": "#/$defs/NpmSpec"
        },
        "pipx": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "dnf": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "apk": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "pacman": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "zypper": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "yum": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "pkg": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "snap": {
          "$ref": "#/$defs/SnapSpec"
        },
        "flatpak": {
          "$ref": "#/$defs/FlatpakSpec"
        },
        "nix": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "go": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "custom": {
          "type": "array",
          "items": { "$ref": "#/$defs/CustomManagerSpec" },
          "default": []
        }
      }
    },
    "BrewSpec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "file": {
          "type": "string",
          "description": "Path to a Brewfile for batch installation"
        },
        "taps": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "formulae": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "casks": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "AptSpec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "file": {
          "type": "string",
          "description": "Path to a file listing APT packages"
        },
        "packages": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "CargoSpec": {
      "description": "Cargo packages. Can be a list of package names or an object with file/packages keys.",
      "oneOf": [
        {
          "type": "array",
          "items": { "type": "string" }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "file": {
              "type": "string"
            },
            "packages": {
              "type": "array",
              "items": { "type": "string" },
              "default": []
            }
          }
        }
      ]
    },
    "NpmSpec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "file": {
          "type": "string",
          "description": "Path to a file listing npm packages"
        },
        "global": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "SnapSpec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "packages": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "classic": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "FlatpakSpec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "packages": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "remote": {
          "type": "string"
        }
      }
    },
    "CustomManagerSpec": {
      "type": "object",
      "required": ["name", "check", "list-installed", "install", "uninstall"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "check": {
          "type": "string"
        },
        "list-installed": {
          "type": "string"
        },
        "install": {
          "type": "string"
        },
        "uninstall": {
          "type": "string"
        },
        "update": {
          "type": "string"
        },
        "packages": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "ManagedFileSpec": {
      "type": "object",
      "required": ["source", "target"],
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "strategy": {
          "type": "string",
          "enum": ["symlink", "copy", "template", "hardlink"],
          "description": "Per-file deployment strategy override"
        },
        "private": {
          "type": "boolean",
          "default": false,
          "description": "When true, the source file is local-only"
        }
      }
    }
  }
}
