  "description": "ConfigSource manifest published by teams for multi-source config management (cfgd-source.yaml)",
  "properties": {
    "apiVersion": {
      "type": "string"
    },
    "kind": {
      "type": "string"
    },
    "metadata": {
      "$ref": "#/definitions/ConfigSourceMetadata"
    },
    "spec": {
      "$ref": "#/definitions/ConfigSourceSpec"
    }
  },
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "title": "cfgd ConfigSource",
  "type": "object"
}
