{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "definitions": {
    "FileSpec": {
      "properties": {
        "content": {
          "type": [
            "string",
            "null"
          ]
        },
        "mode": {
          "default": "0644",
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "source": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "path"
      ],
      "type": "object"
    },
    "ModuleRef": {
      "description": "Reference to a module that should be installed on the machine.",
      "properties": {
        "name": {
          "type": "string"
        },
        "required": {
          "default": false,
          "type": "boolean"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "PackageRef": {
      "description": "Reference to a package with optional version pin.",
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    }
  },
  "properties": {
    "files": {
      "default": [],
      "items": {
        "$ref": "#/definitions/FileSpec"
      },
      "type": "array"
    },
    "hostname": {
      "type": "string"
    },
    "moduleRefs": {
      "default": [],
      "items": {
        "$ref": "#/definitions/ModuleRef"
      },
      "type": "array"
    },
    "packages": {
      "default": [],
      "items": {
        "$ref": "#/definitions/PackageRef"
      },
      "type": "array"
    },
    "profile": {
      "type": "string"
    },
    "systemSettings": {
      "additionalProperties": true,
      "default": {},
      "type": "object"
    }
  },
  "required": [
    "hostname",
    "profile"
  ],
  "title": "MachineConfigSpec",
  "type": "object"
}