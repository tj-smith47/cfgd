{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MachineConfigSpec",
  "type": "object",
  "properties": {
    "files": {
      "type": "array",
      "default": [],
      "items": {
        "$ref": "#/$defs/FileSpec"
      }
    },
    "hostname": {
      "type": "string"
    },
    "moduleRefs": {
      "type": "array",
      "default": [],
      "items": {
        "$ref": "#/$defs/ModuleRef"
      }
    },
    "packages": {
      "type": "array",
      "default": [],
      "items": {
        "$ref": "#/$defs/PackageRef"
      }
    },
    "profile": {
      "type": "string"
    },
    "systemSettings": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    }
  },
  "required": [
    "hostname",
    "profile"
  ],
  "$defs": {
    "FileSpec": {
      "type": "object",
      "properties": {
        "content": {
          "type": [
            "string",
            "null"
          ]
        },
        "mode": {
          "type": "string",
          "default": "0644"
        },
        "path": {
          "type": "string"
        },
        "source": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "path"
      ]
    },
    "ModuleRef": {
      "description": "Reference to a module that should be installed on the machine.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "required": {
          "type": "boolean",
          "default": false
        }
      },
      "required": [
        "name"
      ]
    },
    "PackageRef": {
      "description": "Reference to a package with optional version pin.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "name"
      ]
    }
  }
}