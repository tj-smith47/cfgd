{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ModuleSpec",
  "type": "object",
  "properties": {
    "depends": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "env": {
      "default": [],
      "type": "array",
      "items": {
        "$ref": "#/definitions/ModuleEnvVar"
      }
    },
    "files": {
      "default": [],
      "type": "array",
      "items": {
        "$ref": "#/definitions/ModuleFileSpec"
      }
    },
    "mountPolicy": {
      "description": "Controls how the module is mounted in pods. `Always` (default): CSI volume + volumeMount on all declared containers + env vars. `Debug`: CSI volume only — no volumeMount or env on declared containers. Only accessible via ephemeral debug containers (`kubectl cfgd debug`).",
      "default": "Always",
      "allOf": [
        {
          "$ref": "#/definitions/MountPolicy"
        }
      ]
    },
    "ociArtifact": {
      "type": [
        "string",
        "null"
      ]
    },
    "packages": {
      "default": [],
      "type": "array",
      "items": {
        "$ref": "#/definitions/PackageEntry"
      }
    },
    "scripts": {
      "default": {},
      "allOf": [
        {
          "$ref": "#/definitions/ModuleScripts"
        }
      ]
    },
    "signature": {
      "anyOf": [
        {
          "$ref": "#/definitions/ModuleSignature"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "definitions": {
    "CosignSignature": {
      "description": "Cosign configuration for OCI artifact signature verification.",
      "type": "object",
      "properties": {
        "certificateIdentity": {
          "description": "Certificate identity pattern for keyless verification (regex).",
          "type": [
            "string",
            "null"
          ]
        },
        "certificateOidcIssuer": {
          "description": "Certificate OIDC issuer pattern for keyless verification (regex).",
          "type": [
            "string",
            "null"
          ]
        },
        "keyless": {
          "description": "Enable keyless verification via Fulcio/Rekor (OIDC identity-based).",
          "default": false,
          "type": "boolean"
        },
        "publicKey": {
          "description": "PEM-encoded public key for static key verification.",
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "ModuleEnvVar": {
      "description": "An environment variable set by a Module.",
      "type": "object",
      "required": [
        "name",
        "value"
      ],
      "properties": {
        "append": {
          "default": false,
          "type": "boolean"
        },
        "name": {
          "type": "string"
        },
        "value": {
          "type": "string"
        }
      }
    },
    "ModuleFileSpec": {
      "description": "A file managed by a Module.",
      "type": "object",
      "required": [
        "source",
        "target"
      ],
      "properties": {
        "source": {
          "type": "string"
        },
        "target": {
          "type": "string"
        }
      }
    },
    "ModuleScripts": {
      "description": "Scripts that run during module lifecycle.",
      "type": "object",
      "properties": {
        "postApply": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "ModuleSignature": {
      "description": "Signature configuration for a Module's OCI artifact.",
      "type": "object",
      "properties": {
        "cosign": {
          "anyOf": [
            {
              "$ref": "#/definitions/CosignSignature"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "MountPolicy": {
      "description": "Controls how a module is exposed to pod containers.",
      "oneOf": [
        {
          "description": "Mount into all declared containers with volumeMount and env vars.",
          "type": "string",
          "enum": [
            "Always"
          ]
        },
        {
          "description": "Stage the CSI volume on the pod but do not mount into declared containers. Only accessible via ephemeral debug containers.",
          "type": "string",
          "enum": [
            "Debug"
          ]
        }
      ]
    },
    "PackageEntry": {
      "description": "An entry in a Module's package list with optional per-platform overrides.",
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "platforms": {
          "description": "Per-platform package name overrides (e.g. {\"brew\": \"gnu-sed\", \"apt\": \"sed\"}).",
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    }
  }
}