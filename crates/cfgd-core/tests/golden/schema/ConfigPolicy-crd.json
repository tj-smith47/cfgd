{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "definitions": {
    "LabelSelector": {
      "description": "Kubernetes-style label selector with match_labels and match_expressions.",
      "properties": {
        "matchExpressions": {
          "default": [],
          "items": {
            "$ref": "#/definitions/LabelSelectorRequirement"
          },
          "type": "array"
        },
        "matchLabels": {
          "additionalProperties": {
            "type": "string"
          },
          "default": {},
          "type": "object"
        }
      },
      "type": "object"
    },
    "LabelSelectorRequirement": {
      "description": "A single requirement for label selector expressions.",
      "properties": {
        "key": {
          "type": "string"
        },
        "operator": {
          "$ref": "#/definitions/SelectorOperator"
        },
        "values": {
          "default": [],
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "key",
        "operator"
      ],
      "type": "object"
    },
    "ModuleRef": {
      "description": "Reference to a module that should be installed on the machine.",
      "properties": {
        "name": {
          "type": "string"
        },
        "required": {
          "default": false,
          "type": "boolean"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "PackageRef": {
      "description": "Reference to a package with optional version pin.",
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "SelectorOperator": {
      "enum": [
        "In",
        "NotIn",
        "Exists",
        "DoesNotExist"
      ],
      "type": "string"
    }
  },
  "properties": {
    "debugModules": {
      "default": [],
      "description": "Modules staged as debug-only (CSI volume without volumeMount on declared containers).",
      "items": {
        "$ref": "#/definitions/ModuleRef"
      },
      "type": "array"
    },
    "packages": {
      "default": [],
      "items": {
        "$ref": "#/definitions/PackageRef"
      },
      "type": "array"
    },
    "requiredModules": {
      "default": [],
      "items": {
        "$ref": "#/definitions/ModuleRef"
      },
      "type": "array"
    },
    "settings": {
      "additionalProperties": true,
      "default": {},
      "type": "object"
    },
    "targetSelector": {
      "$ref": "#/definitions/LabelSelector",
      "default": {
        "matchExpressions": [],
        "matchLabels": {}
      }
    }
  },
  "title": "ConfigPolicySpec",
  "type": "object"
}