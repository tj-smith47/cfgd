{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CfgdConfig",
  "type": "object",
  "properties": {
    "apiVersion": {
      "type": "string"
    },
    "kind": {
      "type": "string"
    },
    "metadata": {
      "$ref": "#/$defs/ConfigMetadata"
    },
    "spec": {
      "$ref": "#/$defs/ConfigSpec"
    }
  },
  "additionalProperties": false,
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "$defs": {
    "AiConfig": {
      "type": "object",
      "properties": {
        "apiKeyEnv": {
          "type": "string",
          "default": "ANTHROPIC_API_KEY"
        },
        "model": {
          "type": "string",
          "default": "claude-sonnet-4-6"
        },
        "provider": {
          "type": "string",
          "default": "claude"
        }
      },
      "additionalProperties": false
    },
    "AutoApplyPolicyConfig": {
      "type": "object",
      "properties": {
        "lockedConflict": {
          "$ref": "#/$defs/PolicyAction",
          "default": "Notify"
        },
        "newOptional": {
          "$ref": "#/$defs/PolicyAction",
          "default": "Ignore"
        },
        "newRecommended": {
          "$ref": "#/$defs/PolicyAction",
          "default": "Notify"
        }
      },
      "additionalProperties": false
    },
    "ComplianceConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "export": {
          "$ref": "#/$defs/ComplianceExport",
          "default": {
            "format": "Json",
            "path": "~/.local/state/cfgd/compliance/"
          }
        },
        "interval": {
          "type": "string",
          "default": "1h"
        },
        "retention": {
          "type": "string",
          "default": "30d"
        },
        "scope": {
          "$ref": "#/$defs/ComplianceScope",
          "default": {
            "files": true,
            "packages": true,
            "secrets": true,
            "system": true,
            "watchPackageManagers": [],
            "watchPaths": []
          }
        }
      },
      "additionalProperties": false
    },
    "ComplianceExport": {
      "type": "object",
      "properties": {
        "format": {
          "$ref": "#/$defs/ComplianceFormat",
          "default": "Json"
        },
        "path": {
          "type": "string",
          "default": "~/.local/state/cfgd/compliance/"
        }
      },
      "additionalProperties": false
    },
    "ComplianceFormat": {
      "type": "string",
      "enum": [
        "Json",
        "Yaml"
      ]
    },
    "ComplianceScope": {
      "type": "object",
      "properties": {
        "files": {
          "type": "boolean",
          "default": true
        },
        "packages": {
          "type": "boolean",
          "default": true
        },
        "secrets": {
          "type": "boolean",
          "default": true
        },
        "system": {
          "type": "boolean",
          "default": true
        },
        "watchPackageManagers": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "watchPaths": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "ConfigMetadata": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "name"
      ]
    },
    "ConfigSpec": {
      "type": "object",
      "properties": {
        "ai": {
          "description": "AI assistant configuration: provider, model, and API key env var.",
          "anyOf": [
            {
              "$ref": "#/$defs/AiConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "aliases": {
          "description": "CLI aliases: map of alias name → command string.\nBuilt-in defaults (add, remove) can be overridden or extended.",
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "default": {}
        },
        "compliance": {
          "description": "Compliance snapshot configuration.",
          "anyOf": [
            {
              "$ref": "#/$defs/ComplianceConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "daemon": {
          "anyOf": [
            {
              "$ref": "#/$defs/DaemonConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "fileStrategy": {
          "description": "Global default file deployment strategy. Per-file overrides take precedence.",
          "$ref": "#/$defs/FileStrategy",
          "default": "Symlink"
        },
        "modules": {
          "description": "Module configuration: registries and security.",
          "anyOf": [
            {
              "$ref": "#/$defs/ModulesConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "origin": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/OriginSpec"
          }
        },
        "profile": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "secrets": {
          "anyOf": [
            {
              "$ref": "#/$defs/SecretsConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "security": {
          "description": "Security settings for source signature verification.",
          "anyOf": [
            {
              "$ref": "#/$defs/SecurityConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "sources": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/SourceSpec"
          }
        },
        "theme": {
          "anyOf": [
            {
              "$ref": "#/$defs/ThemeConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "update": {
          "description": "Update policy for the cfgd binary and authored skills.",
          "anyOf": [
            {
              "$ref": "#/$defs/UpdateConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "additionalProperties": false
    },
    "DaemonConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "notify": {
          "anyOf": [
            {
              "$ref": "#/$defs/NotifyConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "reconcile": {
          "anyOf": [
            {
              "$ref": "#/$defs/ReconcileConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "sync": {
          "anyOf": [
            {
              "$ref": "#/$defs/SyncConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "windowsEventLog": {
          "description": "Mirror daemon log output into the Windows Event Log under the `cfgd`\nsource, in addition to the default file appender at\n`%LOCALAPPDATA%\\cfgd\\daemon.log`. No effect on Unix. Read by\n`cfgd daemon install` to bake `--enable-event-log` into the service\nbinPath; changes require reinstalling the service to take effect.",
          "type": "boolean",
          "default": false
        }
      },
      "additionalProperties": false
    },
    "DriftPolicy": {
      "description": "Daemon drift reconciliation policy. PascalCase values match K8s enum conventions.",
      "oneOf": [
        {
          "description": "Apply drift corrections automatically (current behavior, now opt-in).",
          "type": "string",
          "const": "Auto"
        },
        {
          "description": "Notify and record drift, but do not apply. User must run `cfgd apply`.",
          "type": "string",
          "const": "NotifyOnly"
        },
        {
          "description": "Future: notify with actionable prompt.",
          "type": "string",
          "const": "Prompt"
        }
      ]
    },
    "FileStrategy": {
      "description": "File deployment strategy.",
      "oneOf": [
        {
          "description": "Create a symbolic link from target to source (default).",
          "type": "string",
          "const": "Symlink"
        },
        {
          "description": "Copy source content to target.",
          "type": "string",
          "const": "Copy"
        },
        {
          "description": "Render a Tera template and write the output (auto-selected for .tera files).",
          "type": "string",
          "const": "Template"
        },
        {
          "description": "Create a hard link from target to source.",
          "type": "string",
          "const": "Hardlink"
        }
      ]
    },
    "ModuleRegistryEntry": {
      "description": "A module registry — a git repo containing modules in `modules/<name>/module.yaml` structure.",
      "type": "object",
      "properties": {
        "name": {
          "description": "Short name / alias for this source (defaults to GitHub org name).",
          "type": "string"
        },
        "url": {
          "description": "Git URL of the source repository.",
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "name",
        "url"
      ]
    },
    "ModuleSecurityConfig": {
      "type": "object",
      "properties": {
        "requireSignatures": {
          "description": "Require GPG/SSH signatures on all remote module tags.\nWhen true, unsigned modules are rejected unless `--allow-unsigned` is passed.",
          "type": "boolean",
          "default": false
        }
      },
      "additionalProperties": false
    },
    "ModulesConfig": {
      "type": "object",
      "properties": {
        "registries": {
          "description": "Module registries — git repos containing modules in a prescribed directory structure.",
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/ModuleRegistryEntry"
          }
        },
        "security": {
          "description": "Module security settings.",
          "anyOf": [
            {
              "$ref": "#/$defs/ModuleSecurityConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "additionalProperties": false
    },
    "NotifyConfig": {
      "type": "object",
      "properties": {
        "drift": {
          "type": "boolean",
          "default": false
        },
        "method": {
          "$ref": "#/$defs/NotifyMethod",
          "default": "Desktop"
        },
        "webhookUrl": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "NotifyMethod": {
      "type": "string",
      "enum": [
        "Desktop",
        "Stdout",
        "Webhook"
      ]
    },
    "OriginSpec": {
      "type": "object",
      "properties": {
        "auth": {
          "type": [
            "string",
            "null"
          ]
        },
        "branch": {
          "type": "string",
          "default": "master"
        },
        "sshStrictHostKeyChecking": {
          "description": "SSH `StrictHostKeyChecking` policy for git operations.\n`AcceptNew` (default): accept first-seen keys, reject changed keys.\n`Yes`: require keys to already exist in known_hosts (high-security).\n`No`: accept any key (insecure, not recommended).",
          "$ref": "#/$defs/SshHostKeyPolicy",
          "default": "AcceptNew"
        },
        "type": {
          "$ref": "#/$defs/OriginType"
        },
        "url": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "type",
        "url"
      ]
    },
    "OriginType": {
      "type": "string",
      "enum": [
        "Git",
        "Server"
      ]
    },
    "PolicyAction": {
      "type": "string",
      "enum": [
        "Notify",
        "Accept",
        "Reject",
        "Ignore"
      ]
    },
    "ReconcileConfig": {
      "type": "object",
      "properties": {
        "autoApply": {
          "type": "boolean",
          "default": false
        },
        "driftPolicy": {
          "description": "Policy for daemon auto-reconciliation of detected drift.\n`Auto` = silently apply (must opt-in), `NotifyOnly` = notify but don't\napply (safe default), `Prompt` = future interactive approval.",
          "$ref": "#/$defs/DriftPolicy",
          "default": "NotifyOnly"
        },
        "interval": {
          "type": "string",
          "default": "5m"
        },
        "onChange": {
          "type": "boolean",
          "default": false
        },
        "patches": {
          "description": "Per-module or per-profile reconcile overrides (kustomize-style patches).\nEach patch targets a specific Module or Profile by name and overrides\nindividual reconcile fields. Precedence: Module patch > Profile patch > global.",
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/ReconcilePatch"
          }
        },
        "policy": {
          "anyOf": [
            {
              "$ref": "#/$defs/AutoApplyPolicyConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "additionalProperties": false
    },
    "ReconcilePatch": {
      "description": "A kustomize-style reconcile patch targeting a specific module or profile.\nWhen `name` is omitted, the patch applies to all entities of the given kind.",
      "type": "object",
      "properties": {
        "autoApply": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "driftPolicy": {
          "anyOf": [
            {
              "$ref": "#/$defs/DriftPolicy"
            },
            {
              "type": "null"
            }
          ]
        },
        "interval": {
          "type": [
            "string",
            "null"
          ]
        },
        "kind": {
          "$ref": "#/$defs/ReconcilePatchKind"
        },
        "name": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "kind"
      ]
    },
    "ReconcilePatchKind": {
      "type": "string",
      "enum": [
        "Module",
        "Profile"
      ]
    },
    "SecretIntegration": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        }
      },
      "additionalProperties": true,
      "required": [
        "name"
      ]
    },
    "SecretsConfig": {
      "type": "object",
      "properties": {
        "backend": {
          "type": "string",
          "default": "sops"
        },
        "integrations": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/SecretIntegration"
          }
        },
        "sops": {
          "anyOf": [
            {
              "$ref": "#/$defs/SopsConfig"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "SecurityConfig": {
      "type": "object",
      "properties": {
        "allowUnsigned": {
          "description": "Allow unsigned source content even when the source requires signed commits.\nIntended for development/testing environments.",
          "type": "boolean",
          "default": false
        }
      },
      "additionalProperties": false
    },
    "SkillUpdateConfig": {
      "description": "Update configuration specific to authored skills.",
      "type": "object",
      "properties": {
        "policy": {
          "description": "How skill update checks behave. Defaults to `Inherit` (defer to the\nbinary-level policy).",
          "$ref": "#/$defs/SkillUpdatePolicy",
          "default": "Inherit"
        }
      },
      "additionalProperties": false
    },
    "SkillUpdatePolicy": {
      "description": "Per-skill update policy. Mirrors [`UpdatePolicy`] but adds `Inherit`, which\ndefers to the binary-level [`UpdateConfig::policy`].",
      "oneOf": [
        {
          "description": "Defer to the binary-level update policy ([`UpdateConfig::policy`]).",
          "type": "string",
          "const": "Inherit"
        },
        {
          "description": "Apply skill updates automatically without prompting.",
          "type": "string",
          "const": "Auto"
        },
        {
          "description": "Ask before applying an available skill update.",
          "type": "string",
          "const": "Prompt"
        },
        {
          "description": "Report that a skill update is available, but take no action.",
          "type": "string",
          "const": "Notify"
        },
        {
          "description": "Disable automatic skill update checks; the user updates manually.",
          "type": "string",
          "const": "Manual"
        }
      ]
    },
    "SopsConfig": {
      "type": "object",
      "properties": {
        "ageKey": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "SourceSpec": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "origin": {
          "$ref": "#/$defs/OriginSpec"
        },
        "subscription": {
          "$ref": "#/$defs/SubscriptionSpec",
          "default": {
            "acceptRecommended": false,
            "allowScripts": false,
            "optIn": [],
            "overrides": null,
            "priority": 500,
            "reject": null
          }
        },
        "sync": {
          "$ref": "#/$defs/SourceSyncSpec",
          "default": {
            "autoApply": false,
            "interval": "1h",
            "required": false
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "name",
        "origin"
      ]
    },
    "SourceSyncSpec": {
      "type": "object",
      "properties": {
        "autoApply": {
          "type": "boolean",
          "default": false
        },
        "interval": {
          "type": "string",
          "default": "1h"
        },
        "pinVersion": {
          "type": [
            "string",
            "null"
          ]
        },
        "required": {
          "description": "Fail-closed marker. When `true`, a failure to load this source (fetch,\nmanifest, signature, or an unresolvable `pinVersion`) is fatal — apply /\nplan / compose abort rather than silently dropping the source. Default\n`false` keeps the best-effort warn-and-continue behaviour for optional\nsources. Use it for security or team baselines that must always be\ncomposed in.",
          "type": "boolean",
          "default": false
        }
      },
      "additionalProperties": false
    },
    "SshHostKeyPolicy": {
      "description": "SSH `StrictHostKeyChecking` policy for git operations over SSH.",
      "oneOf": [
        {
          "description": "Accept first-seen keys, reject changed keys (safe default for automation).",
          "type": "string",
          "const": "AcceptNew"
        },
        {
          "description": "Require keys to already exist in known_hosts (high-security environments).",
          "type": "string",
          "const": "Yes"
        },
        {
          "description": "Accept any key without verification (insecure, not recommended).",
          "type": "string",
          "const": "No"
        }
      ]
    },
    "SubscriptionSpec": {
      "type": "object",
      "properties": {
        "acceptRecommended": {
          "type": "boolean",
          "default": false
        },
        "allowScripts": {
          "description": "Subscriber opt-in to run lifecycle scripts (profile-layer and\nsource-delivered module bodies) from this source even when the source's\n`constraints.no_scripts` would otherwise reject them. Default `false`:\nthe source's own `no_scripts` constraint governs.",
          "type": "boolean",
          "default": false
        },
        "optIn": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          }
        },
        "overrides": {
          "default": null
        },
        "priority": {
          "type": "integer",
          "format": "uint32",
          "default": 500,
          "minimum": 0
        },
        "profile": {
          "type": [
            "string",
            "null"
          ]
        },
        "reject": {
          "default": null
        }
      },
      "additionalProperties": false
    },
    "SyncConfig": {
      "type": "object",
      "properties": {
        "autoPull": {
          "type": "boolean",
          "default": false
        },
        "autoPush": {
          "type": "boolean",
          "default": false
        },
        "interval": {
          "type": "string",
          "default": "1h"
        }
      },
      "additionalProperties": false
    },
    "ThemeConfig": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "default": "default"
        },
        "overrides": {
          "$ref": "#/$defs/ThemeOverrides"
        }
      }
    },
    "ThemeOverrides": {
      "type": "object",
      "properties": {
        "accent": {
          "type": [
            "string",
            "null"
          ]
        },
        "diffAdd": {
          "type": [
            "string",
            "null"
          ]
        },
        "diffContext": {
          "type": [
            "string",
            "null"
          ]
        },
        "diffRemove": {
          "type": [
            "string",
            "null"
          ]
        },
        "error": {
          "type": [
            "string",
            "null"
          ]
        },
        "header": {
          "type": [
            "string",
            "null"
          ]
        },
        "iconArrow": {
          "type": [
            "string",
            "null"
          ]
        },
        "iconFail": {
          "type": [
            "string",
            "null"
          ]
        },
        "iconOk": {
          "type": [
            "string",
            "null"
          ]
        },
        "iconPending": {
          "type": [
            "string",
            "null"
          ]
        },
        "iconRunning": {
          "type": [
            "string",
            "null"
          ]
        },
        "iconSkipped": {
          "type": [
            "string",
            "null"
          ]
        },
        "iconWarn": {
          "type": [
            "string",
            "null"
          ]
        },
        "info": {
          "type": [
            "string",
            "null"
          ]
        },
        "muted": {
          "type": [
            "string",
            "null"
          ]
        },
        "running": {
          "type": [
            "string",
            "null"
          ]
        },
        "secondary": {
          "type": [
            "string",
            "null"
          ]
        },
        "success": {
          "type": [
            "string",
            "null"
          ]
        },
        "warning": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "UpdateConfig": {
      "description": "Configuration for cfgd self-update checks and authored-skill updates.",
      "type": "object",
      "properties": {
        "channel": {
          "description": "Release channel to track (e.g. `stable`, `beta`). When unset, cfgd uses\nits built-in default channel.",
          "type": [
            "string",
            "null"
          ]
        },
        "interval": {
          "description": "How often to check for updates, as a duration string (e.g. `24h`, `7d`,\n`30m`) or a plain number of seconds. Defaults to `24h`.",
          "type": "string",
          "default": "24h"
        },
        "policy": {
          "description": "How update checks for the cfgd binary behave. Defaults to `Prompt`.",
          "$ref": "#/$defs/UpdatePolicy",
          "default": "Prompt"
        },
        "skills": {
          "description": "Update policy for authored skills. Defaults to inheriting `policy`.",
          "$ref": "#/$defs/SkillUpdateConfig",
          "default": {
            "policy": "Inherit"
          }
        }
      },
      "additionalProperties": false
    },
    "UpdatePolicy": {
      "description": "Update policy governing how cfgd self-update checks behave.\n\n`Auto` applies updates without prompting, `Prompt` asks before applying,\n`Notify` only reports that an update is available, and `Manual` disables\nautomatic checks entirely (the user runs `cfgd upgrade` themselves).",
      "oneOf": [
        {
          "description": "Apply updates automatically without prompting.",
          "type": "string",
