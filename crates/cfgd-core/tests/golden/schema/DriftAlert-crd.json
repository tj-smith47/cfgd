{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DriftAlertSpec",
  "type": "object",
  "properties": {
    "deviceId": {
      "type": "string"
    },
    "driftDetails": {
      "type": "array",
      "default": [],
      "items": {
        "$ref": "#/$defs/DriftDetail"
      }
    },
    "machineConfigRef": {
      "$ref": "#/$defs/MachineConfigReference"
    },
    "severity": {
      "$ref": "#/$defs/DriftSeverity"
    }
  },
  "required": [
    "deviceId",
    "machineConfigRef",
    "severity"
  ],
  "$defs": {
    "DriftDetail": {
      "type": "object",
      "properties": {
        "actual": {
          "type": "string"
        },
        "expected": {
          "type": "string"
        },
        "field": {
          "type": "string"
        }
      },
      "required": [
        "field",
        "expected",
        "actual"
      ]
    },
    "DriftSeverity": {
      "type": "string",
      "enum": [
        "Low",
        "Medium",
        "High",
        "Critical"
      ]
    },
    "MachineConfigReference": {
      "description": "Typed reference to a MachineConfig resource.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "namespace": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "name"
      ]
    }
  }
}