# Ignore everything
*

# Allow Rust source
!Cargo.toml
!Cargo.lock
!crates/
!crates/**

# cfgd-core embeds these repo-root example manifests via include_str! at
# compile time, so every image that builds a cfgd-core-dependent binary needs
# them in the build context.
!examples/
!examples/**

# Allow build files
!Dockerfile
!Dockerfile.*

# Allow pre-built binaries (release Docker builds)
!binaries/
!binaries/**

# Allow tests
!tests/
!tests/**

# Allow README for labels
!README.md

# Re-ignore build artifacts inside allowed dirs
target/
