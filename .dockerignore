# Ignore everything
*

# Allow Rust source
!Cargo.toml
!Cargo.lock
!crates/
!crates/**

# Allow build files
!Dockerfile
!Dockerfile.*

# Allow pre-built binaries (release Docker builds)
!binaries/
!binaries/**

# Allow tests
!tests/
!tests/**

# Allow README for labels
!README.md

# Re-ignore build artifacts inside allowed dirs
target/
